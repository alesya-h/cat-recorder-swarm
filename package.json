{
  "name": "cat-recorder",
  "private": true,
  "version": "0.1.0",
  "type": "module",
  "scripts": {
    "dev": "concurrently \"node --watch server/server.js\" \"vite\"",
    "dev:server": "node --watch server/server.js",
    "dev:web": "vite",
    "build": "vite build",
    "start": "node server/server.js",
    "start:https": "AUTO_HTTPS=1 node server/server.js"
  },
  "dependencies": {
    "express": "^4.21.2",
    "libflacjs": "^5.4.0",
    "react": "^18.3.1",
    "react-dom": "^18.3.1",
    "selfsigned": "^5.5.0",
    "ws": "^8.18.3"
  },
  "devDependencies": {
    "@vitejs/plugin-react": "^4.3.4",
    "concurrently": "^9.1.2",
    "vite": "^5.4.12"
  }
}
